---
import BaseLayout from '../layouts/BaseLayout.astro';
import { workExperience, researchExperience } from '../data/displayData';
---

<BaseLayout title="David Chung - Experience" activePage="experience">
  <section class="section bio-section">
    <p class="bio-text">Studying Information Systems and Computer Science at Carnegie Mellon</p>
  </section>

  <section class="section" id="work">
    <h2 class="section-title">WORK</h2>
    <div class="experience-list">
      {workExperience.map((exp) => (
        <div class="experience-item clickable-work" data-company-url={exp.companyUrl}>
          <img src={exp.logo} alt={exp.org} class:list={["experience-logo", exp.logoClass]} />
          <div class="experience-content">
            <div class="experience-header">
              <div class="experience-header-left">
                <div class="experience-org">{exp.org}</div>
                <div class="experience-role">{exp.role}</div>
              </div>
              <div class="experience-date">{exp.date}</div>
            </div>
            <div class="experience-footer">
              <div class="experience-desc">{exp.desc}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="section" id="research">
    <h2 class="section-title">RESEARCH</h2>
    <div class="experience-list">
      {researchExperience.map((exp) => (
        exp.org === "CMU G-CLef Lab" ? (
          <div class="experience-item expandable-item" data-expandable="gclef">
            <div class="experience-item-header">
              <img src={exp.logo} alt={exp.org} class:list={["experience-logo", exp.logoClass]} />
              <div class="experience-content">
                <div class="experience-header">
                  <div class="experience-header-left">
                    <div class="experience-org">{exp.org}</div>
                    <div class="experience-role">{exp.role}</div>
                  </div>
                  <div class="experience-date">{exp.date}</div>
                </div>
                <div class="experience-footer">
                  <div class="experience-desc">{exp.desc}</div>
                </div>
              </div>
              <svg class="expand-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </div>
            <div class="expandable-content">
              <div class="expandable-links">
                <a href="https://arxiv.org/abs/2607.01849" target="_blank" rel="noopener noreferrer" class="expandable-link">
                  <span class="expandable-link-text">Paper</span>
                  <svg class="expandable-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
                <a href="https://yewon-kim.com/decomposer/" target="_blank" rel="noopener noreferrer" class="expandable-link">
                  <span class="expandable-link-text">Website</span>
                  <svg class="expandable-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
                <a href="https://gclef-cmu.org/" target="_blank" rel="noopener noreferrer" class="expandable-link">
                  <span class="expandable-link-text">Lab</span>
                  <svg class="expandable-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ) : (
          <div class="experience-item clickable-work" data-company-url={exp.companyUrl}>
            <img src={exp.logo} alt={exp.org} class:list={["experience-logo", exp.logoClass]} />
            <div class="experience-content">
              <div class="experience-header">
                <div class="experience-header-left">
                  <div class="experience-org">{exp.org}</div>
                  <div class="experience-role">{exp.role}</div>
                </div>
                <div class="experience-date">{exp.date}</div>
              </div>
              <div class="experience-footer">
                <div class="experience-desc">{exp.desc}</div>
              </div>
            </div>
          </div>
        )
      ))}
    </div>
  </section>
</BaseLayout>

<script is:inline src="/scripts/expandable-experience.js"></script>
